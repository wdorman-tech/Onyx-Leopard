        { "name": "AWS AI & Bedrock Expansion", "description": "Position AWS as the leading AI cloud platform with Bedrock (managed foundation models), Trainium/Inferentia custom AI chips, and SageMaker. Target $150B+ AWS revenue.", "priority": 1 },
        { "name": "Advertising Scaling (Prime Video Ads)", "description": "Introduce ads on Prime Video (200M+ viewers), expand sponsored product formats, and grow retail media network to $80B+. Highest-margin business segment.", "priority": 2 },
